# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side only: Supabase service role key (bypasses RLS - keep secret, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Bolt Fleet API
BOLT_CLIENT_ID=your_bolt_client_id
BOLT_CLIENT_SECRET=your_bolt_client_secret
BOLT_API_BASE_URL=https://node.bolt.eu/fleet-owner/v1

# Uber API
UBER_APP_ID=your_uber_app_id
UBER_SECRET=your_uber_secret
UBER_API_BASE_URL=https://api.uber.com/v1

# App URL (for email links). Production: https://app.rovora.eu
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Rovora

# Push Notifications (Web Push VAPID keys)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=admin@yourdomain.com

# Email Notifications (Resend)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=Rovora <noreply@rovora.eu>

# Stripe Billing
# Secret key from https://dashboard.stripe.com/test/apikeys (use the TEST key while developing)
STRIPE_SECRET_KEY=sk_test_xxx
# Webhook signing secret. Local: `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# prints whsec_...  Production: copy it from the webhook endpoint you create in the dashboard.
STRIPE_WEBHOOK_SECRET=whsec_xxx
