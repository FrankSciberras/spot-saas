# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Bolt Fleet API
BOLT_CLIENT_ID=your_bolt_client_id
BOLT_CLIENT_SECRET=your_bolt_client_secret
BOLT_API_BASE_URL=https://node.bolt.eu/fleet-owner/v1

# Uber API
UBER_APP_ID=your_uber_app_id
UBER_SECRET=your_uber_secret
UBER_API_BASE_URL=https://api.uber.com/v1

# App URL (for email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SPOT Dashboard

# Push Notifications (Web Push VAPID keys)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=admin@yourdomain.com

# Email Notifications (Resend)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=SPOT Dashboard <noreply@yourdomain.com>
